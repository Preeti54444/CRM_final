rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to get user role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    // Helper function to check if user is manager
    function isManager() {
      return isAuthenticated() && getUserRole() == 'manager';
    }
    
    // Helper function to check if user is sales executive
    function isSalesExecutive() {
      return isAuthenticated() && (getUserRole() == 'sales_executive' || getUserRole() == 'telecaller');
    }
    
    // Users collection - role-based access
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated();
    }
    
    // Contacts collection - role-based access
    match /contacts/{contactId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Leads collection - role-based access
    match /leads/{leadId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Deals collection - role-based access
    match /deals/{dealId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Tasks collection - role-based access
    match /tasks/{taskId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Activities collection - role-based access
    match /activities/{activityId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Meetings collection - role-based access
    match /meetings/{meetingId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Calls collection - role-based access
    match /calls/{callId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Accounts collection - role-based access
    match /accounts/{accountId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Campaigns collection - role-based access
    match /campaigns/{campaignId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Documents collection - role-based access
    match /documents/{documentId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Reports collection (SOD, EOD, WOD) - role-based access
    match /reports/{reportId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Settings collection - role-based access
    match /settings/{settingId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    // Employees collection - role-based access
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
